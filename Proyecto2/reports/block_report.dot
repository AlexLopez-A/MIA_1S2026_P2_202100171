digraph Blocks {
  rankdir=LR;
  node [shape=plaintext];
  block0 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD COLSPAN="2" BGCOLOR="#81C784"><B>Dir Block 0</B></TD></TR>
    <TR><TD>.</TD><TD>0</TD></TR>
    <TR><TD>..</TD><TD>0</TD></TR>
    <TR><TD>users.txt</TD><TD>1</TD></TR>
    <TR><TD>home</TD><TD>2</TD></TR>
    </TABLE>
  >];
  block1 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD BGCOLOR="#FFD54F"><B>File Block 1</B></TD></TR>
    <TR><TD>1,G,root\n1,U,root,root,123\n</TD></TR>
    </TABLE>
  >];
  block2 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD COLSPAN="2" BGCOLOR="#81C784"><B>Dir Block 2</B></TD></TR>
    <TR><TD>.</TD><TD>2</TD></TR>
    <TR><TD>..</TD><TD>0</TD></TR>
    <TR><TD>user</TD><TD>3</TD></TR>
    <TR><TD></TD><TD>-1</TD></TR>
    </TABLE>
  >];
  block3 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD COLSPAN="2" BGCOLOR="#81C784"><B>Dir Block 3</B></TD></TR>
    <TR><TD>.</TD><TD>3</TD></TR>
    <TR><TD>..</TD><TD>2</TD></TR>
    <TR><TD>docs</TD><TD>4</TD></TR>
    <TR><TD></TD><TD>-1</TD></TR>
    </TABLE>
  >];
  block4 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD COLSPAN="2" BGCOLOR="#81C784"><B>Dir Block 4</B></TD></TR>
    <TR><TD>.</TD><TD>4</TD></TR>
    <TR><TD>..</TD><TD>3</TD></TR>
    <TR><TD>hello.txt</TD><TD>5</TD></TR>
    <TR><TD></TD><TD>-1</TD></TR>
    </TABLE>
  >];
  block5 [label=<
    <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
    <TR><TD BGCOLOR="#FFD54F"><B>File Block 5</B></TD></TR>
    <TR><TD>01234567890123456789012345678901234567890123456789</TD></TR>
    </TABLE>
  >];
  block0 -> block1;
  block1 -> block2;
  block2 -> block3;
  block3 -> block4;
  block4 -> block5;
}
